<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ProgressBar android:id="@+id/progress_bar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:indeterminateTint="@color/gabchat_green"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tv_empty"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Aucune conversation.\nCommencez à chatter !"
        android:textAlignment="center" android:textColor="@color/text_secondary"
        android:textSize="15sp" android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_conversations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorSurface"
        android:divider="@null" />
</androidx.constraintlayout.widget.ConstraintLayout>
